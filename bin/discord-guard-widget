#!/usr/bin/env python3
import json
import subprocess
import sys
import warnings
from pathlib import Path

import gi
import cairo

warnings.filterwarnings("ignore", category=DeprecationWarning)
gi.require_version("Gtk", "3.0")
gi.require_version("Gdk", "3.0")
from gi.repository import Gdk, GLib, Gtk  # noqa: E402


HOME = Path.home()
GUARD = HOME / ".local/bin/discord-guard"
ICON_PATH = HOME / ".local/share/icons/hicolor/scalable/apps/discord-guard.svg"
GITHUB_URL = "https://github.com/Diogolima-creator/discord-guard"
DAY_OPTIONS = [
    ("mon", "Seg"),
    ("tue", "Ter"),
    ("wed", "Qua"),
    ("thu", "Qui"),
    ("fri", "Sex"),
    ("sat", "Sab"),
    ("sun", "Dom"),
]


CSS = """
.liquid-shell {
  font-family: "Ubuntu Sans", "Noto Sans", sans-serif;
  background-color: rgba(42, 16, 53, 0.52);
  background-image:
    radial-gradient(circle at 8% 0%, rgba(255,255,255,0.32), transparent 26%),
    radial-gradient(circle at 90% 12%, rgba(156,231,194,0.24), transparent 32%),
    radial-gradient(circle at 28% 120%, rgba(88,101,242,0.34), transparent 40%),
    linear-gradient(145deg, rgba(255,255,255,0.18), rgba(255,255,255,0.055));
  border: 1px solid rgba(255,255,255,0.28);
  border-radius: 24px;
  box-shadow: 0 24px 70px rgba(0,0,0,0.48);
  padding: 18px;
}

.liquid-header {
  padding: 2px 2px 10px 2px;
}

.guard-kicker {
  color: rgba(247,251,255,0.68);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1.4px;
}

.guard-title {
  color: #f7fbff;
  font-size: 24px;
  font-weight: 800;
  text-shadow: 0 2px 16px rgba(88,101,242,0.44);
}

.guard-details {
  color: rgba(247,251,255,0.90);
  font-size: 13.5px;
  background-color: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.14);
  border-radius: 16px;
  padding: 14px;
}

.guard-button {
  color: #f7fbff;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.24);
  border-radius: 999px;
  padding: 9px 13px;
  box-shadow: inset 0 1px rgba(255,255,255,0.24);
}

.guard-button:hover {
  background: rgba(156,231,194,0.22);
  border-color: rgba(156,231,194,0.55);
}

.config-entry {
  color: #f7fbff;
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.22);
  border-radius: 12px;
  padding: 8px 10px;
}

.config-label {
  color: rgba(247,251,255,0.76);
  font-size: 12px;
  font-weight: 700;
}

.config-check {
  color: rgba(247,251,255,0.92);
}

.config-error {
  color: #ffd5dc;
  font-size: 12px;
}

.config-block {
  background-color: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.14);
  border-radius: 14px;
  padding: 10px;
}

.window-control {
  color: rgba(247,251,255,0.88);
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: 12px;
  min-width: 24px;
  min-height: 24px;
  font-size: 16px;
  font-weight: 700;
  padding: 0;
  margin: 0;
  box-shadow: inset 0 1px rgba(255,255,255,0.22);
}

.window-control-label {
  padding: 0;
  margin: 0;
  color: rgba(247,251,255,0.90);
  font-size: 15px;
  font-weight: 800;
}

.window-control:hover {
  background: rgba(255,96,118,0.30);
  border-color: rgba(255,155,170,0.48);
}
"""


class DiscordGuardWidget:
    def __init__(self) -> None:
        self.window: Gtk.Window | None = None
        self.config_window: Gtk.Window | None = None
        self.status_label = Gtk.Label()
        self.details_label = Gtk.Label()
        self.install_css()
        self.icon = self.new_status_icon()
        self.icon.set_tooltip_text("Discord Guard")
        self.icon.set_visible(True)
        self.icon.connect("activate", self.show_window)
        self.icon.connect("popup-menu", self.show_menu)
        self.refresh()
        GLib.timeout_add_seconds(30, self.refresh)

    def install_css(self) -> None:
        provider = Gtk.CssProvider()
        provider.load_from_data(CSS.encode("utf-8"))
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

    def new_status_icon(self) -> Gtk.StatusIcon:
        if ICON_PATH.exists():
            return Gtk.StatusIcon.new_from_file(str(ICON_PATH))
        return Gtk.StatusIcon.new_from_icon_name("discord")

    def guard_json(self) -> dict:
        try:
            result = subprocess.run(
                [str(GUARD), "status", "--json"],
                check=True,
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
            )
            return json.loads(result.stdout)
        except Exception as exc:
            return {
                "effective_blocked": True,
                "scheduled_blocked": True,
                "reason": f"erro lendo status: {exc}",
                "next_change": None,
                "blocked_until": None,
                "unlocked_until": None,
            }

    def run_guard(self, args: list[str]) -> subprocess.CompletedProcess:
        return subprocess.run(
            [str(GUARD), *args],
            check=False,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )

    def refresh(self) -> bool:
        status = self.guard_json()
        blocked = bool(status.get("effective_blocked"))
        scheduled = bool(status.get("scheduled_blocked"))
        unlocked_until = status.get("unlocked_until")

        if blocked:
            icon_name = str(ICON_PATH) if ICON_PATH.exists() else "dialog-error"
            title = "Discord bloqueado"
        elif scheduled and unlocked_until:
            icon_name = str(ICON_PATH) if ICON_PATH.exists() else "dialog-warning"
            title = "Discord liberado temporariamente"
        else:
            icon_name = str(ICON_PATH) if ICON_PATH.exists() else "discord"
            title = "Discord liberado"

        if Path(icon_name).exists():
            self.icon.set_from_file(icon_name)
        else:
            self.icon.set_from_icon_name(icon_name)
        self.icon.set_tooltip_text(self.tooltip(status, title))
        if self.window:
            self.update_window_labels(status, title)
        return True

    def tooltip(self, status: dict, title: str) -> str:
        parts = [title]
        if status.get("blocked_until"):
            parts.append(f"Bloqueado ate: {status['blocked_until']}")
        if status.get("unlocked_until"):
            parts.append(f"Liberado ate: {status['unlocked_until']}")
        if status.get("next_change"):
            parts.append(f"Proxima mudanca: {status['next_change']}")
        return "\n".join(parts)

    def update_window_labels(self, status: dict, title: str) -> None:
        self.status_label.set_markup(f"<b>{GLib.markup_escape_text(title)}</b>")
        lines = [
            f"Estado: {title}",
            f"Regra: {status.get('schedule') or '-'}",
            "Escopo: bloqueia o app desktop do Discord; nao bloqueia Discord no navegador.",
            f"Motivo: {status.get('reason')}",
            f"Proxima mudanca: {status.get('next_change') or '-'}",
            f"Bloqueado ate: {status.get('blocked_until') or '-'}",
            f"Liberado ate: {status.get('unlocked_until') or '-'}",
            "",
            "Durante o bloqueio, abrir o Discord pede um codigo temporario.",
        ]
        self.details_label.set_text("\n".join(lines))

    def clear_window_background(self, _widget: Gtk.Widget, cr: cairo.Context) -> bool:
        cr.set_operator(cairo.OPERATOR_CLEAR)
        cr.paint()
        cr.set_operator(cairo.OPERATOR_OVER)
        return False

    def begin_window_drag(self, widget: Gtk.Widget, event: Gdk.EventButton) -> bool:
        if event.button == 1 and self.window:
            self.window.begin_move_drag(event.button, int(event.x_root), int(event.y_root), event.time)
            return True
        return False

    def show_window(self, *_args) -> None:
        if self.window:
            self.window.present()
            self.refresh()
            return

        self.window = Gtk.Window(title="Discord Guard")
        self.window.set_default_size(560, 350)
        self.window.set_border_width(0)
        self.window.set_decorated(False)
        self.window.set_app_paintable(True)
        visual = self.window.get_screen().get_rgba_visual()
        if visual:
            self.window.set_visual(visual)
        self.window.connect("draw", self.clear_window_background)
        self.window.connect("delete-event", self.hide_window)

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.get_style_context().add_class("liquid-shell")
        self.window.add(box)

        header = Gtk.EventBox()
        header.connect("button-press-event", self.begin_window_drag)
        header_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        header_box.get_style_context().add_class("liquid-header")
        header.add(header_box)

        title_stack = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        title_stack.set_hexpand(True)
        kicker = Gtk.Label(label="DISCORD GUARD")
        kicker.set_xalign(0)
        kicker.get_style_context().add_class("guard-kicker")
        title_stack.pack_start(kicker, False, False, 0)
        self.status_label.set_xalign(0)
        self.status_label.get_style_context().add_class("guard-title")
        title_stack.pack_start(self.status_label, False, False, 0)
        header_box.pack_start(title_stack, True, True, 0)

        close_button = Gtk.EventBox()
        close_button.set_size_request(24, 24)
        close_button.set_halign(Gtk.Align.CENTER)
        close_button.set_valign(Gtk.Align.START)
        close_button.get_style_context().add_class("window-control")
        close_button.connect("button-press-event", self.hide_window)
        close_label = Gtk.Label(label="×")
        close_label.set_size_request(24, 24)
        close_label.set_halign(Gtk.Align.CENTER)
        close_label.set_valign(Gtk.Align.CENTER)
        close_label.get_style_context().add_class("window-control-label")
        close_button.add(close_label)
        header_box.pack_start(close_button, False, False, 0)

        self.details_label.set_xalign(0)
        self.details_label.set_selectable(False)
        self.details_label.get_style_context().add_class("guard-details")

        box.pack_start(header, False, False, 0)
        box.pack_start(self.details_label, True, True, 0)

        buttons = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        box.pack_start(buttons, False, False, 0)

        open_button = Gtk.Button(label="Abrir Discord")
        open_button.get_style_context().add_class("guard-button")
        open_button.connect("clicked", lambda *_: subprocess.Popen([str(GUARD), "launch"]))
        buttons.pack_start(open_button, False, False, 0)

        unlock_button = Gtk.Button(label="Liberar com codigo")
        unlock_button.get_style_context().add_class("guard-button")
        unlock_button.connect("clicked", lambda *_: subprocess.Popen([str(GUARD), "unlock"]))
        buttons.pack_start(unlock_button, False, False, 0)

        config_button = Gtk.Button(label="Configurar horario")
        config_button.get_style_context().add_class("guard-button")
        config_button.connect("clicked", self.show_config_window)
        buttons.pack_start(config_button, False, False, 0)

        refresh_button = Gtk.Button(label="Atualizar")
        refresh_button.get_style_context().add_class("guard-button")
        refresh_button.connect("clicked", lambda *_: self.refresh())
        buttons.pack_start(refresh_button, False, False, 0)

        repo_button = Gtk.Button(label="GitHub")
        repo_button.get_style_context().add_class("guard-button")
        repo_button.connect("clicked", lambda *_: subprocess.Popen(["xdg-open", GITHUB_URL]))
        buttons.pack_start(repo_button, False, False, 0)

        self.refresh()
        self.window.show_all()

    def hide_window(self, *_args) -> bool:
        if self.window:
            self.window.hide()
        return True

    def show_config_window(self, *_args) -> None:
        if self.config_window:
            self.config_window.present()
            return

        status = self.guard_json()
        config = status.get("config") or {}
        blocks = config.get("blocks") or [
            {"start": "20:00", "end": "06:00", "days": ["mon", "tue", "wed", "thu"]}
        ]

        self.config_window = Gtk.Window(title="Configurar horario")
        self.config_window.set_default_size(620, 520)
        self.config_window.set_border_width(0)
        self.config_window.set_decorated(False)
        self.config_window.set_app_paintable(True)
        visual = self.config_window.get_screen().get_rgba_visual()
        if visual:
            self.config_window.set_visual(visual)
        self.config_window.connect("draw", self.clear_window_background)
        self.config_window.connect("delete-event", self.hide_config_window)

        shell = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        shell.get_style_context().add_class("liquid-shell")
        self.config_window.add(shell)

        header = Gtk.EventBox()
        header.connect("button-press-event", self.begin_config_window_drag)
        header_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        header_box.get_style_context().add_class("liquid-header")
        header.add(header_box)

        title_stack = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        title_stack.set_hexpand(True)
        kicker = Gtk.Label(label="AGENDA")
        kicker.set_xalign(0)
        kicker.get_style_context().add_class("guard-kicker")
        title_stack.pack_start(kicker, False, False, 0)
        title = Gtk.Label(label="Configurar bloqueios")
        title.set_xalign(0)
        title.get_style_context().add_class("guard-title")
        title_stack.pack_start(title, False, False, 0)
        header_box.pack_start(title_stack, True, True, 0)

        close = Gtk.EventBox()
        close.set_size_request(24, 24)
        close.set_halign(Gtk.Align.CENTER)
        close.set_valign(Gtk.Align.START)
        close.get_style_context().add_class("window-control")
        close.connect("button-press-event", self.hide_config_window)
        close_label = Gtk.Label(label="×")
        close_label.set_size_request(24, 24)
        close_label.get_style_context().add_class("window-control-label")
        close.add(close_label)
        header_box.pack_start(close, False, False, 0)
        shell.pack_start(header, False, False, 0)

        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroll.set_min_content_height(300)
        blocks_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        scroll.add(blocks_box)
        shell.pack_start(scroll, True, True, 0)

        block_rows: list[dict] = []
        for block in blocks:
            self.add_block_row(blocks_box, block_rows, block)

        error_label = Gtk.Label()
        error_label.set_xalign(0)
        error_label.set_line_wrap(True)
        error_label.get_style_context().add_class("config-error")
        shell.pack_start(error_label, False, False, 0)

        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        shell.pack_start(actions, False, False, 0)

        add = Gtk.Button(label="Adicionar bloco")
        add.get_style_context().add_class("guard-button")
        add.connect("clicked", lambda *_: self.add_block_row(blocks_box, block_rows))
        actions.pack_start(add, False, False, 0)

        save = Gtk.Button(label="Salvar")
        save.get_style_context().add_class("guard-button")
        save.connect(
            "clicked",
            self.save_config_from_ui,
            block_rows,
            error_label,
        )
        actions.pack_start(save, False, False, 0)

        cancel = Gtk.Button(label="Cancelar")
        cancel.get_style_context().add_class("guard-button")
        cancel.connect("clicked", self.hide_config_window)
        actions.pack_start(cancel, False, False, 0)

        self.config_window.show_all()

    def add_block_row(
        self,
        blocks_box: Gtk.Box,
        block_rows: list[dict],
        block: dict | None = None,
    ) -> None:
        block = block or {"start": "20:00", "end": "06:00", "days": ["mon", "tue", "wed", "thu"]}
        active_days = set(block.get("days") or [])

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        card.get_style_context().add_class("config-block")

        top = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        card.pack_start(top, False, False, 0)

        start_entry = Gtk.Entry()
        start_entry.set_text(str(block.get("start") or "20:00"))
        start_entry.set_placeholder_text("20:00")
        start_entry.set_width_chars(7)
        start_entry.get_style_context().add_class("config-entry")
        end_entry = Gtk.Entry()
        end_entry.set_text(str(block.get("end") or "06:00"))
        end_entry.set_placeholder_text("06:00")
        end_entry.set_width_chars(7)
        end_entry.get_style_context().add_class("config-entry")

        start_label = Gtk.Label(label="Inicio")
        start_label.get_style_context().add_class("config-label")
        end_label = Gtk.Label(label="Fim")
        end_label.get_style_context().add_class("config-label")

        start_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        start_box.pack_start(start_label, False, False, 0)
        start_box.pack_start(start_entry, False, False, 0)
        end_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        end_box.pack_start(end_label, False, False, 0)
        end_box.pack_start(end_entry, False, False, 0)
        top.pack_start(start_box, False, False, 0)
        top.pack_start(end_box, False, False, 0)

        days_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        checks: dict[str, Gtk.CheckButton] = {}
        for day, label in DAY_OPTIONS:
            check = Gtk.CheckButton(label=label)
            check.set_active(day in active_days)
            check.get_style_context().add_class("config-check")
            checks[day] = check
            days_box.pack_start(check, False, False, 0)
        card.pack_start(days_box, False, False, 0)

        remove = Gtk.Button(label="Remover")
        remove.get_style_context().add_class("guard-button")
        top.pack_end(remove, False, False, 0)

        row = {"card": card, "start": start_entry, "end": end_entry, "checks": checks}

        def remove_row(*_args) -> None:
            if row in block_rows:
                block_rows.remove(row)
            blocks_box.remove(card)
            blocks_box.show_all()

        remove.connect("clicked", remove_row)
        block_rows.append(row)
        blocks_box.pack_start(card, False, False, 0)
        blocks_box.show_all()

    def save_config_from_ui(
        self,
        _button: Gtk.Button,
        block_rows: list[dict],
        error_label: Gtk.Label,
    ) -> None:
        blocks = []
        for index, row in enumerate(block_rows, start=1):
            days = [day for day, check in row["checks"].items() if check.get_active()]
            if not days:
                error_label.set_text(f"Bloco {index}: escolha pelo menos um dia.")
                return
            blocks.append(
                {
                    "start": row["start"].get_text().strip(),
                    "end": row["end"].get_text().strip(),
                    "days": days,
                }
            )
        if not blocks:
            error_label.set_text("Adicione pelo menos um bloco.")
            return
        result = self.run_guard(
            [
                "config",
                "set",
                "--blocks",
                json.dumps(blocks),
            ]
        )
        if result.returncode != 0:
            error_label.set_text((result.stderr or result.stdout or "Erro salvando config.").strip())
            return
        error_label.set_text("")
        self.hide_config_window()
        self.refresh()

    def hide_config_window(self, *_args) -> bool:
        if self.config_window:
            self.config_window.destroy()
            self.config_window = None
        return True

    def begin_config_window_drag(self, _widget: Gtk.Widget, event: Gdk.EventButton) -> bool:
        if event.button == 1 and self.config_window:
            self.config_window.begin_move_drag(event.button, int(event.x_root), int(event.y_root), event.time)
            return True
        return False

    def show_menu(self, _icon, button: int, activate_time: int) -> None:
        menu = Gtk.Menu()
        items = [
            ("Mostrar status", self.show_window),
            ("Configurar horario", self.show_config_window),
            ("Abrir Discord", lambda *_: subprocess.Popen([str(GUARD), "launch"])),
            ("Liberar com codigo", lambda *_: subprocess.Popen([str(GUARD), "unlock"])),
            ("Sair do widget", lambda *_: Gtk.main_quit()),
        ]
        for label, callback in items:
            item = Gtk.MenuItem(label=label)
            item.connect("activate", callback)
            menu.append(item)
        menu.show_all()
        menu.popup(None, None, None, None, button, activate_time)


def main() -> int:
    if not GUARD.exists():
        print(f"{GUARD} nao encontrado. Rode ./install.sh primeiro.", file=sys.stderr)
        return 1
    widget = DiscordGuardWidget()
    if "--show" in sys.argv[1:]:
        GLib.idle_add(widget.show_window)
    Gtk.main()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
