#!/usr/bin/env python3
import argparse
import base64
import datetime as dt
import hashlib
import hmac
import json
import os
import secrets
import subprocess
import sys
import time
from pathlib import Path


HOME = Path.home()
CONFIG_DIR = HOME / ".config" / "discord-guard"
CACHE_DIR = HOME / ".cache" / "discord-guard"
CONFIG_FILE = CONFIG_DIR / "config.json"
SECRET_FILE = CONFIG_DIR / "totp_secret"
UNLOCK_FILE = CACHE_DIR / "unlocked_until"
DEFAULT_CONFIG = {
    "blocks": [
        {
            "start": "20:00",
            "end": "06:00",
            "days": ["mon", "tue", "wed", "thu"],
        }
    ],
}
DAY_NAMES = ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]
DAY_LABELS = {
    "mon": "segunda",
    "tue": "terca",
    "wed": "quarta",
    "thu": "quinta",
    "fri": "sexta",
    "sat": "sabado",
    "sun": "domingo",
}
REAL_DISCORD = [Path("/usr/share/discord/Discord"), Path("/snap/bin/discord")]
KILL_PATTERNS = [
    "/usr/share/discord/Discord",
    "/snap/discord/",
    "/snap/bin/discord",
]


def now() -> dt.datetime:
    override = os.environ.get("DISCORD_GUARD_NOW")
    if override:
        parsed = dt.datetime.fromisoformat(override)
        if parsed.tzinfo is None:
            return parsed.astimezone()
        return parsed
    return dt.datetime.now().astimezone()


def parse_time(value: str) -> dt.time:
    try:
        hour, minute = value.split(":", 1)
        return dt.time(hour=int(hour), minute=int(minute))
    except ValueError as exc:
        raise ValueError(f"horario invalido: {value!r}. Use HH:MM.") from exc


def normalize_days(raw_days: list[str] | str) -> list[str]:
    if isinstance(raw_days, str):
        raw_days = [part.strip() for part in raw_days.split(",")]
    normalized = []
    for day in raw_days:
        key = day.strip().lower()
        if key not in DAY_NAMES:
            raise ValueError(f"dia invalido: {day!r}. Use: {', '.join(DAY_NAMES)}")
        if key not in normalized:
            normalized.append(key)
    if not normalized:
        raise ValueError("days nao pode ficar vazio.")
    return normalized


def normalize_block(raw: dict) -> dict:
    if not isinstance(raw, dict):
        raise ValueError("cada bloco precisa ser um objeto JSON.")
    start = parse_time(str(raw.get("start", "20:00")))
    end = parse_time(str(raw.get("end", "06:00")))
    days = normalize_days(raw.get("days", []))
    return {
        "start": start.strftime("%H:%M"),
        "end": end.strftime("%H:%M"),
        "days": days,
    }


def normalize_config(raw: dict) -> dict:
    if "blocks" in raw:
        raw_blocks = raw["blocks"]
    else:
        raw_blocks = [
            {
                "start": raw.get("start", "20:00"),
                "end": raw.get("end", "06:00"),
                "days": raw.get("days", ["mon", "tue", "wed", "thu"]),
            }
        ]
    if not isinstance(raw_blocks, list) or not raw_blocks:
        raise ValueError("config precisa ter pelo menos um bloco em blocks[].")
    return {"blocks": [normalize_block(block) for block in raw_blocks]}


def load_config() -> dict:
    config = dict(DEFAULT_CONFIG)
    if CONFIG_FILE.exists():
        try:
            loaded = json.loads(CONFIG_FILE.read_text(encoding="utf-8"))
        except json.JSONDecodeError as exc:
            raise ValueError(f"config JSON invalido em {CONFIG_FILE}: {exc}") from exc
        if not isinstance(loaded, dict):
            raise ValueError(f"config invalido em {CONFIG_FILE}: esperado objeto JSON.")
        config = loaded
    return normalize_config(config)


def save_config(config: dict) -> None:
    config = normalize_config(config)
    ensure_dirs()
    CONFIG_FILE.write_text(json.dumps(config, indent=2, ensure_ascii=True) + "\n", encoding="utf-8")
    os.chmod(CONFIG_FILE, 0o600)


def block_label(block: dict) -> str:
    day_text = ", ".join(DAY_LABELS[day] for day in block["days"])
    return f"{day_text}, das {block['start']} ate {block['end']}"


def schedule_label(config: dict) -> str:
    return " | ".join(block_label(block) for block in config["blocks"])


def window_for_start_day(current: dt.datetime, start_day: dt.date, block: dict) -> tuple[dt.datetime, dt.datetime]:
    start_time = parse_time(block["start"])
    end_time = parse_time(block["end"])
    start = dt.datetime.combine(start_day, start_time, tzinfo=current.tzinfo)
    end_date = start_day if end_time > start_time else start_day + dt.timedelta(days=1)
    end = dt.datetime.combine(end_date, end_time, tzinfo=current.tzinfo)
    if end <= start:
        end += dt.timedelta(days=1)
    return start, end


def active_windows(current: dt.datetime) -> list[tuple[dt.datetime, dt.datetime, dict]]:
    config = load_config()
    windows = []
    for block in config["blocks"]:
        allowed_start_days = {DAY_NAMES.index(day) for day in block["days"]}
        for offset in (0, -1):
            start_day = current.date() + dt.timedelta(days=offset)
            if start_day.weekday() not in allowed_start_days:
                continue
            start, end = window_for_start_day(current, start_day, block)
            if start <= current < end:
                windows.append((start, end, block))
    return windows


def blocked_window(current: dt.datetime) -> tuple[bool, dt.datetime | None, str]:
    config = load_config()
    windows = active_windows(current)
    if windows:
        until = max(end for _, end, _ in windows)
        active_labels = " | ".join(block_label(block) for _, _, block in windows)
        return True, until, f"inside configured schedule: {active_labels}"
    return False, None, f"outside configured schedule: {schedule_label(config)}"


def next_change(current: dt.datetime) -> dt.datetime:
    config = load_config()
    current_state = bool(active_windows(current))
    candidates = set()
    for block in config["blocks"]:
        allowed_start_days = {DAY_NAMES.index(day) for day in block["days"]}
        for offset in range(-1, 9):
            start_day = current.date() + dt.timedelta(days=offset)
            if start_day.weekday() not in allowed_start_days:
                continue
            start, end = window_for_start_day(current, start_day, block)
            candidates.add(start)
            candidates.add(end)
    for candidate in sorted(candidates):
        if candidate <= current:
            continue
        if bool(active_windows(candidate)) != current_state:
            return candidate
    return current + dt.timedelta(days=1)


def ensure_dirs() -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CACHE_DIR.mkdir(parents=True, exist_ok=True)


def read_unlock_until() -> dt.datetime | None:
    try:
        raw = UNLOCK_FILE.read_text(encoding="utf-8").strip()
    except FileNotFoundError:
        return None
    if not raw:
        return None
    try:
        parsed = dt.datetime.fromisoformat(raw)
    except ValueError:
        return None
    if parsed.tzinfo is None:
        parsed = parsed.astimezone()
    return parsed


def is_unlocked(current: dt.datetime) -> bool:
    until = read_unlock_until()
    return bool(until and current < until)


def set_unlocked_until(until: dt.datetime) -> None:
    ensure_dirs()
    UNLOCK_FILE.write_text(until.isoformat(), encoding="utf-8")
    os.chmod(UNLOCK_FILE, 0o600)


def notify(title: str, body: str) -> None:
    if os.environ.get("DISCORD_GUARD_NO_NOTIFY"):
        return
    try:
        subprocess.run(["notify-send", title, body], check=False)
    except FileNotFoundError:
        pass


def real_discord_path() -> Path | None:
    for candidate in REAL_DISCORD:
        if candidate.exists() and os.access(candidate, os.X_OK):
            return candidate
    return None


def launch_real(args: list[str]) -> int:
    target = real_discord_path()
    if not target:
        print("Discord real nao encontrado.", file=sys.stderr)
        return 127
    subprocess.Popen([str(target), *args], start_new_session=True)
    return 0


def kill_discord() -> bool:
    killed = False
    for pattern in KILL_PATTERNS:
        result = subprocess.run(["pkill", "-f", pattern], check=False)
        killed = killed or result.returncode == 0
    return killed


def secret_bytes() -> bytes:
    raw = SECRET_FILE.read_text(encoding="utf-8").strip().replace(" ", "")
    return base64.b32decode(raw.upper(), casefold=True)


def totp(secret: bytes, for_time: int | None = None, step: int = 30, digits: int = 6) -> str:
    if for_time is None:
        for_time = int(time.time())
    counter = int(for_time // step)
    msg = counter.to_bytes(8, "big")
    digest = hmac.new(secret, msg, hashlib.sha1).digest()
    offset = digest[-1] & 0x0F
    code = int.from_bytes(digest[offset : offset + 4], "big") & 0x7FFFFFFF
    return str(code % (10**digits)).zfill(digits)


def verify_code(code: str) -> bool:
    if not SECRET_FILE.exists():
        print("TOTP ainda nao configurado. Rode: discord-guard setup-totp", file=sys.stderr)
        return False
    clean = "".join(ch for ch in code if ch.isdigit())
    if len(clean) != 6:
        return False
    secret = secret_bytes()
    current = int(time.time())
    return any(hmac.compare_digest(clean, totp(secret, current + offset)) for offset in (-30, 0, 30))


def prompt_code() -> str:
    try:
        result = subprocess.run(
            ["zenity", "--entry", "--title=Discord bloqueado", "--text=Codigo temporario:"],
            check=False,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
        )
        if result.returncode == 0:
            return result.stdout.strip()
    except FileNotFoundError:
        pass
    return input("Codigo temporario: ").strip()


def status_payload(current: dt.datetime) -> dict[str, str | bool | None]:
    config = load_config()
    is_blocked, until, reason = blocked_window(current)
    unlocked_until = read_unlock_until()
    if unlocked_until and unlocked_until <= current:
        unlocked_until = None
    effective_blocked = is_blocked and not is_unlocked(current)
    return {
        "now": current.isoformat(timespec="seconds"),
        "scheduled_blocked": is_blocked,
        "effective_blocked": effective_blocked,
        "reason": reason,
        "next_change": next_change(current).isoformat(timespec="seconds"),
        "blocked_until": until.isoformat(timespec="seconds") if until else None,
        "unlocked_until": unlocked_until.isoformat(timespec="seconds") if unlocked_until else None,
        "schedule": schedule_label(config),
        "config": config,
    }


def cmd_setup_totp(_: argparse.Namespace) -> int:
    ensure_dirs()
    if SECRET_FILE.exists():
        print(f"Segredo ja existe em {SECRET_FILE}")
        print("Remova esse arquivo manualmente se quiser gerar outro.")
        return 0

    secret = base64.b32encode(secrets.token_bytes(20)).decode("ascii").rstrip("=")
    padding = "=" * ((8 - len(secret) % 8) % 8)
    SECRET_FILE.write_text(secret + padding + "\n", encoding="utf-8")
    os.chmod(SECRET_FILE, 0o600)
    print("Configure este segredo em um app autenticador ou guarde fora do seu uso diario:")
    print(secret)
    print("Conta: discord-guard")
    print("Emissor: local")
    return 0


def cmd_status(args: argparse.Namespace) -> int:
    payload = status_payload(now())
    if args.json:
        print(json.dumps(payload, ensure_ascii=True))
        return 0

    print(f"agora: {payload['now']}")
    print(f"agenda_bloqueada: {'sim' if payload['scheduled_blocked'] else 'nao'} ({payload['reason']})")
    print(f"agenda: {payload['schedule']}")
    print(f"bloqueio_efetivo: {'sim' if payload['effective_blocked'] else 'nao'}")
    print(f"proxima_mudanca: {payload['next_change']}")
    if payload["blocked_until"]:
        print(f"bloqueado_ate: {payload['blocked_until']}")
    if payload["unlocked_until"]:
        print(f"liberado_ate: {payload['unlocked_until']}")
    return 0


def cmd_config_show(args: argparse.Namespace) -> int:
    config = load_config()
    if args.json:
        print(json.dumps(config, ensure_ascii=True))
    else:
        for index, block in enumerate(config["blocks"], start=1):
            print(f"block {index}: {block['start']} -> {block['end']} days={','.join(block['days'])}")
        print(f"agenda: {schedule_label(config)}")
    return 0


def cmd_config_set(args: argparse.Namespace) -> int:
    if args.blocks:
        try:
            blocks = json.loads(args.blocks)
        except json.JSONDecodeError as exc:
            raise ValueError(f"blocks JSON invalido: {exc}") from exc
        config = normalize_config({"blocks": blocks})
        save_config(config)
        print(f"Config salva em {CONFIG_FILE}")
        print(f"agenda: {schedule_label(config)}")
        return 0

    block = load_config()["blocks"][0]
    if args.start:
        block["start"] = parse_time(args.start).strftime("%H:%M")
    if args.end:
        block["end"] = parse_time(args.end).strftime("%H:%M")
    if args.days:
        block["days"] = normalize_days(args.days)
    config = {"blocks": [block]}
    save_config(config)
    print(f"Config salva em {CONFIG_FILE}")
    print(f"agenda: {schedule_label(config)}")
    return 0


def cmd_launch(args: argparse.Namespace) -> int:
    current = now()
    is_blocked, until, _ = blocked_window(current)
    if not is_blocked or is_unlocked(current):
        return launch_real(args.discord_args)

    message = f"Discord bloqueado ate {until.strftime('%H:%M')}."
    notify("Discord bloqueado", message)
    print(message)
    code = prompt_code()
    if verify_code(code):
        set_unlocked_until(until)
        notify("Discord liberado", f"Liberado ate {until.strftime('%H:%M')}.")
        return launch_real(args.discord_args)

    notify("Discord bloqueado", "Codigo invalido.")
    print("Codigo invalido.", file=sys.stderr)
    return 1


def cmd_unlock(_: argparse.Namespace) -> int:
    current = now()
    is_blocked, until, _ = blocked_window(current)
    if not is_blocked or not until:
        print("Fora do horario bloqueado; nada para liberar.")
        return 0
    code = prompt_code()
    if not verify_code(code):
        print("Codigo invalido.", file=sys.stderr)
        return 1
    set_unlocked_until(until)
    print(f"Discord liberado ate {until.isoformat(timespec='seconds')}")
    return 0


def cmd_enforce(_: argparse.Namespace) -> int:
    current = now()
    is_blocked, until, _ = blocked_window(current)
    if not is_blocked or is_unlocked(current):
        return 0
    if kill_discord():
        notify("Discord fechado", f"Bloqueado ate {until.strftime('%H:%M')}.")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Guardrail local de horario para o Discord.")
    sub = parser.add_subparsers(dest="command", required=True)

    sub.add_parser("setup-totp").set_defaults(func=cmd_setup_totp)

    status = sub.add_parser("status")
    status.add_argument("--json", action="store_true")
    status.set_defaults(func=cmd_status)

    config = sub.add_parser("config")
    config_sub = config.add_subparsers(dest="config_command", required=True)
    config_show = config_sub.add_parser("show")
    config_show.add_argument("--json", action="store_true")
    config_show.set_defaults(func=cmd_config_show)
    config_set = config_sub.add_parser("set")
    config_set.add_argument("--start", help="Horario inicial HH:MM")
    config_set.add_argument("--end", help="Horario final HH:MM")
    config_set.add_argument("--days", help="Dias de inicio: mon,tue,wed,thu,fri,sat,sun")
    config_set.add_argument("--blocks", help="JSON com lista de blocos [{start,end,days}]")
    config_set.set_defaults(func=cmd_config_set)

    sub.add_parser("enforce").set_defaults(func=cmd_enforce)
    sub.add_parser("unlock").set_defaults(func=cmd_unlock)

    launch = sub.add_parser("launch")
    launch.add_argument("discord_args", nargs=argparse.REMAINDER)
    launch.set_defaults(func=cmd_launch)
    return parser


def main() -> int:
    args = build_parser().parse_args()
    try:
        return args.func(args)
    except ValueError as exc:
        print(f"Erro: {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
